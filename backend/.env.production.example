# Backend Environment Variables Template
# Copy this file and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Earth Engine
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=/app/gee-credentials.json

# Alternative: Provide GEE credentials as JSON string
# GEE_CREDENTIALS={"type":"service_account","project_id":"..."}

# CORS Origins (comma-separated)
CORS_ORIGINS=["https://your-frontend.vercel.app","http://localhost:3001"]

# Python Configuration
PYTHONUNBUFFERED=1

# Optional: API Configuration
API_HOST=0.0.0.0
API_PORT=8002
