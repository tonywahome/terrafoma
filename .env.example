# ========================================
# TerraFoma Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values
# Never commit .env to git!

# ---- Google Earth Engine (REQUIRED) ----
# Get these from: https://console.cloud.google.com/
EARTHENGINE_PROJECT_ID=your-gee-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ---- Supabase Database (OPTIONAL - for persistent storage) ----
# If not set, app uses in-memory database with 5 sample credits
# Get these from: https://app.supabase.com → Settings → API
# See docs/SUPABASE_SETUP.md for detailed setup guide

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-starting-with-eyJ
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-starting-with-eyJ

# Optional: Direct PostgreSQL connection (only if needed)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- Backend Configuration ----
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8002
CORS_ORIGINS=http://localhost:3001,http://localhost:8501

# ML Model paths (default values work out of the box)
MODEL_PATH=./ml/models/biomass_model_v1.pkl
INTEGRITY_MODEL_PATH=./ml/integrity_model.pkl

# ---- Frontend (Next.js) ----
# Get Mapbox token from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# Optional: Frontend Supabase access (for client-side auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-starting-with-eyJ

# ========================================
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Add your Google Earth Engine project ID
# 3. Add your Mapbox token (required for maps)
# 4. (Optional) Add Supabase keys for persistent database
# 5. Restart servers
#
# See docs/SETUP.md for detailed instructions
# See docs/SUPABASE_SETUP.md for database setup
# ========================================
